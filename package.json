{
  "name": "@nimbus-dev/sdk",
  "version": "1.5.0",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nimbus-agent/nimbus-sdk.git"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./testing": {
      "bun": "./src/testing/index.ts",
      "types": "./dist/testing/index.d.ts",
      "import": "./dist/testing/index.js",
      "default": "./dist/testing/index.js"
    },
    "./ipc": {
      "bun": "./src/ipc/index.ts",
      "types": "./dist/ipc/index.d.ts",
      "import": "./dist/ipc/index.js",
      "default": "./dist/ipc/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "build": "tsc --project tsconfig.build.json",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.test.json",
    "lint": "biome check src/",
    "test": "bun test",
    "clean": "rm -rf dist",
    "prepublishOnly": "bun run build && bun run typecheck",
    "test:coverage": "bun test --coverage --coverage-reporter=lcov src",
    "test:coverage:sdk": "bun test --coverage src"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.1",
    "@types/bun": "^1.3.14",
    "typescript": "^7.0.2"
  }
}
