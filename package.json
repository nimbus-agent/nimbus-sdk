{
  "name": "@nimbus-dev/sdk",
  "version": "1.0.0",
  "license": "MIT",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts"
    },
    "./testing": {
      "import": "./src/testing/index.ts",
      "types": "./src/testing/index.ts"
    },
    "./ipc": {
      "import": "./src/ipc/index.ts",
      "types": "./src/ipc/index.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "build": "tsc --project tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src/",
    "test": "bun test",
    "clean": "rm -rf dist",
    "prepublishOnly": "bun run build && bun run typecheck",
    "test:coverage:sdk": "bun test --coverage src"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^6.0.2"
  }
}
