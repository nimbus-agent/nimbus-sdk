{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./dist",
    "noEmit": false,
    "allowImportingTsExtensions": false,
    "rootDir": "./src"
  },
  // Pinned, NOT inherited: the base include now also covers scripts/ so editors resolve
  // those files to a real project, but rootDir is ./src so they must not reach the build.
  // The *.test.ts exclude below is load-bearing — this package co-locates its tests in src/.
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "**/*.test.ts"]
}
